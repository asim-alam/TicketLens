# QueueStorm Investigator — environment variable NAMES only (no real values).
# Copy to .env.local for local dev (gitignored). Set real values in the Vercel
# project env vars for deployment, NOT in the repo.
#
# The service is a COMPLETE, deterministic, rules-only solution by default.
# The LLM layer below is OPTIONAL and OFF unless USE_LLM=true/1.

APP_ENV=development

# ----- Optional LLM fallback (OFF by default) -----
# Set USE_LLM=true to allow LLM refinement of LOW-confidence, NON-safety tickets only.
# Safety + escalation always stay rule-driven regardless of this flag.
USE_LLM=false
LLM_PROVIDER=

# OpenAI-compatible provider. Primary: Groq (fast, free tier).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Backup providers (one-line swap of the two vars above):
#   Cerebras: LLM_BASE_URL=https://api.cerebras.ai/v1            LLM_MODEL=llama-3.3-70b
#   Gemini  : LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

LLM_TIMEOUT_SECONDS=2
LLM_TIMEOUT_S=3.5
LLM_CONFIDENCE_FLOOR=0.6

# Local server port (uvicorn). Vercel sets its own.
PORT=8000
