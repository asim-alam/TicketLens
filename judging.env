# Committed safe defaults for automated judges and Docker fallback.
# The app is fully deterministic with USE_LLM=false and needs no API key.
USE_LLM=false
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_S=3.5
LLM_CONFIDENCE_FLOOR=0.6
PORT=8000
